# ZenMux OpenAI-compatible endpoint (DeepSeek via proxy)
DEEPSEEK_API_KEY=sk-xxx-your-zenmux-key
DEEPSEEK_BASE_URL=https://zenmux.ai/api/v1
DEEPSEEK_MODEL=deepseek/deepseek-v3.2

# ─── M2: 模型网关 (One-API) ───
# 留空 = 维持 M1 行为（直连 ZenMux / dashscope）。
# 配上 = 所有 chat / embed 走 One-API（OpenAI 兼容）。
# OPENAI_API_BASE_URL=http://one-api:3000/v1
# OPENAI_API_KEY=sk-xxx-issued-by-one-api

# 场景→模型路由（M2，未配置则全部回落到 DEEPSEEK_MODEL / EMBEDDING_MODEL）
# MODEL_ROUTER_DEFAULT=deepseek-chat
# MODEL_CHAT_DEFAULT=deepseek-chat
# MODEL_ANALYSIS_DEFAULT=deepseek-chat
# MODEL_EMBEDDING_DEFAULT=qwen-text-embedding-v3

# ─── M2: 可观测 (Langfuse) ───
# 三个一起为空 → 不上报 trace；任一缺失也按未配置处理。
# LANGFUSE_HOST=http://langfuse:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# LANGFUSE_SECRET_KEY=sk-lf-xxx

# Local pgvector-backed RAG
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xg1

# 讯飞开放平台（语音听写 / 录音文件转写）
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
