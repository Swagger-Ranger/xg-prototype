# 前端 Web 构建 Dockerfile
#
# [DEPRECATED 2026-05-18]
# 已不在 docker-compose.yml 中引用。前端构建改为本地 `pnpm build` 直接产出 dist，
# 由 deploy/scripts/build-local.sh + sync-to-cloud.sh 同步到云上，nginx bind mount。
# 此文件保留仅作为"无本地 Node 环境时容器内 fallback 构建"的备选方案，可手动:
#   docker buildx build --platform linux/amd64 \
#     -f deploy/Dockerfile.web -t xg-web:tag xg-frontend/
# 后续如确认无人使用，可整体删除。
#
# 历史用途：在 Docker 中构建前端，避免在服务器安装 Node.js

FROM node:20-alpine AS builder

WORKDIR /app

# 安装 pnpm
RUN npm install -g pnpm@9.1.0

# 复制 workspace 配置文件
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./

# 复制 packages（共享依赖）
COPY packages ./packages

# 复制 web 应用
COPY apps/web/package.json apps/web/
COPY apps/web/tsconfig.json apps/web/
COPY apps/web/vite.config.ts apps/web/
COPY apps/web/vitest.config.ts apps/web/
COPY apps/web/index.html apps/web/
COPY apps/web/src apps/web/src
COPY apps/web/public apps/web/public

# 安装依赖并构建
RUN pnpm install --frozen-lockfile
RUN pnpm run build --filter=@xg1/web

# 构建完成后，将产物复制到 /output 目录（用于挂载到卷）
RUN mkdir -p /output && cp -r /app/apps/web/dist/* /output/

# 输出目录: /output
