# ============================================
# 演示环境专用配置（轻量、快速）
# ============================================

# Database
DB_PASS=postgres123

# Redis
REDIS_PASS=redis123

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# AI
AI_INTERNAL_TOKEN=demo-internal-token

# LLM API Keys（演示环境可不填）
QWEN_API_KEY=
DEEPSEEK_API_KEY=

# Grafana
GRAFANA_PASS=admin123

# ============================================
# 演示环境优化配置
# ============================================

# 超级管理员密码
SUPERADMIN_INITIAL_PASSWORD=admin123

# Java 内存优化（演示环境 512MB 足够）
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200
JAVA_MEM_LIMIT=1G

# Python 内存优化
PYTHON_MEM_LIMIT=256M
PYTHON_WORKERS=1

# PostgreSQL 内存优化
PG_SHARED_BUFFERS=128MB
PG_EFFECTIVE_CACHE=256MB
PG_WORK_MEM=4MB
PG_MAINT_MEM=32MB
PG_MEM_LIMIT=512M

# Redis 内存优化
REDIS_MAXMEM=64mb
REDIS_MEM_LIMIT=128M

# MinIO 内存优化
MINIO_MEM_LIMIT=128M
