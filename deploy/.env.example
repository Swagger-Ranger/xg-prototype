# ============================================
# 环境变量示例 — 复制为 .env 后修改
# ============================================
#
# 部署模式选择:
#   开发模式 (~1.2GB):  docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
#   轻量全栈 (~3.5GB):  docker compose --env-file env/lite.env --profile lite up -d
#   标准生产 (~7.5GB):  docker compose --env-file env/full.env --profile full up -d
#

# Database
DB_PASS=postgres123

# Redis
REDIS_PASS=redis123

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# AI (Python sidecar ↔ Java 内部通信密钥)
AI_INTERNAL_TOKEN=dev-internal-token

# LLM API Keys (留空则 AI 功能不可用，业务正常运行)
QWEN_API_KEY=

# 切换到 DeepSeek 官方 API（如需用 zenmux，注释掉下面两行即可）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

# Grafana (仅 full profile)
GRAFANA_PASS=admin123

# ============================================
# 宿主机日志目录（容器日志的挂载位置）
# ============================================
# 云服务器（CentOS/Ubuntu 等）推荐：/data/logs（配合 logrotate 自动轮转）
# macOS/Windows 本地开发推荐：./logs（无需 sudo，项目目录内管理）
#
# 默认行为（不配置时）：docker-compose.yml 内使用 /app/logs（容器内部路径，不挂载到宿主机）
#
# HOST_LOG_DIR=/data/logs   # 云服务器标准配置（需要 sudo 创建目录）
# HOST_LOG_DIR=./logs       # 本地开发配置（无需 sudo）

# ============================================
# 超级管理员初始密码（生产环境必须设置）
# ============================================
# 当 platform_admin 表为空时，系统会使用此密码创建默认超级管理员
# 用户名: admin
# 密码: 此处设置的值
# 必须在第一次启动前设置，启动后修改此变量不会影响已有管理员密码
SUPERADMIN_INITIAL_PASSWORD=admin123456

# ============================================
# 低配机器内存优化（可选，4 核 8G 演示机/本地开发）
# ============================================
# 默认配置面向 8 核 16G。低配机器取消下方注释以降低内存占用（约 3GB → 2GB）。
#
# JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200
# JAVA_MEM_LIMIT=1G
#
# PYTHON_MEM_LIMIT=256M
# PYTHON_WORKERS=1
#
# PG_SHARED_BUFFERS=128MB
# PG_EFFECTIVE_CACHE=256MB
# PG_WORK_MEM=4MB
# PG_MAINT_MEM=32MB
# PG_MEM_LIMIT=512M
#
# REDIS_MAXMEM=64mb
# REDIS_MEM_LIMIT=128M
#
# MINIO_MEM_LIMIT=128M
