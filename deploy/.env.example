# ============================================
# 环境变量示例 — 复制为 .env 后修改
# ============================================
#
# 部署模式选择:
#   开发模式 (~1.2GB):  docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
#   轻量全栈 (~3.5GB):  docker compose --env-file env/lite.env --profile lite up -d
#   标准生产 (~7.5GB):  docker compose --env-file env/full.env --profile full up -d
#

# Database
DB_PASS=postgres123

# Redis
REDIS_PASS=redis123

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# AI (Python sidecar ↔ Java 内部通信密钥)
AI_INTERNAL_TOKEN=dev-internal-token

# LLM API Keys (留空则 AI 功能不可用，业务正常运行)
QWEN_API_KEY=
DEEPSEEK_API_KEY=

# Grafana (仅 full profile)
GRAFANA_PASS=admin123

# ============================================
# 超级管理员初始密码（生产环境必须设置）
# ============================================
# 当 platform_admin 表为空时，系统会使用此密码创建默认超级管理员
# 用户名: admin
# 密码: 此处设置的值
# 必须在第一次启动前设置，启动后修改此变量不会影响已有管理员密码
SUPERADMIN_INITIAL_PASSWORD=admin123456
